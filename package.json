{
  "name": "brocade-mcp-server",
  "version": "1.0.0",
  "description": "MCP servers for Brocade ICX 6450 switch automation",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/servers/stdio.ts",
    "start:stdio": "node dist/servers/stdio.js",
    "start:sse": "node dist/servers/sse.js",
    "test": "jest",
    "lint": "eslint 'src/**/*.ts'",
    "biome": "biome check",
    "biome:fix": "biome check --write",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "brocade",
    "icx",
    "icx6450",
    "network",
    "automation",
    "ssh",
    "switch-management",
    "typescript"
  ],
  "author": "Vinnie Esposito",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vespo92/BrocadeICXMCP.git"
  },
  "bugs": {
    "url": "https://github.com/vespo92/BrocadeICXMCP/issues"
  },
  "homepage": "https://github.com/vespo92/BrocadeICXMCP#readme",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ssh2": "^1.17.0",
    "winston": "^3.19.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.0",
    "@types/ssh2": "^1.11.19",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
